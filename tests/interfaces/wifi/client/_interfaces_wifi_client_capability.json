{
    "1": {
        "description": "Set wifi client capability",
        "1.1": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/add",
            "schema": {
                "ifname": "wlan1",
                "mode": "client",
                "phy": 0
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.2": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/client/capability",
            "schema": {
                "ifname": "wlan1",
                "reauth": true
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.3": {
            "type": "GET",
            "endpoint": "/interfaces/wifi/client/capability",
            "arguments": {
                "ifname": "wlan1"
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.4": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/delete",
            "schema": {
                "ifname": "wlan1"
            },
            "errCode": 0,
            "httpCode": 200
        }
    }
}