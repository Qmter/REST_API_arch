{
    "1": {
        "description": "Add wifi interface",
        "1.1": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/add",
            "schema": {
                "ifname": "wlan1",
                "mode": "access-point",
                "phy": 0
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.2": {
            "type": "GET",
            "endpoint": "/interfaces/list",
            "arguments": {
                "category": "wlan"
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.3": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/delete",
            "schema": {
                "ifname": "wlan1"
            },
            "errCode": 0,
            "httpCode": 200
        }
    }   
}