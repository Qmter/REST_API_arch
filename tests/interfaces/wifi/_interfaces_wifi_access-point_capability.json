{
    "1": {
        "description": "Set wifi access point capability",
        "1.1": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/add",
            "schema": {
                "ifname": "wlan1",
                "mode": "access-point",
                "phy": 0
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.2": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/access-point/capability",
            "schema": {
                "ifname": "wlan1",
                "ssid": "1",
                "channel": 0,
                "hide_ssid": true,
                "band": "802.11a",
                "ht_capability": {
                    "HT40-": true,
                    "HT40+": true,
                    "GF": true
                },
                "encryption": "WEP64",
                "wpa_password": {
                    "password": "951dce643CF7B4e83538D9565752EC47BEf90ABFB6227fC4Cd722aaDF0F66CDB",
                    "hash": true
                }
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.3": {
            "type": "GET",
            "endpoint": "/interfaces/wifi/access-point/capability",
            "arguments": {
                "ifname": "wlan1"
            },
            "errCode": 0,
            "httpCode": 200
        },
        "1.4": {
            "type": "GET",
            "endpoint": "/interfaces/wifi/access-point/status",
            "arguments": {
                "ifname": "wlan1"
            },
            "errCode": 6,
            "httpCode": 404
        },
        "1.5": {
            "type": "POST",
            "endpoint": "/interfaces/wifi/delete",
            "schema": {
                "ifname": "wlan1"
            },
            "errCode": 0,
            "httpCode": 200
        }
    }
}